# Neon Postgres (required for data persistence)
DATABASE_URL=

# AI (required for chat API routes)
ANTHROPIC_API_KEY=
# Optional — tiered model overrides. Defaults: fast=claude-sonnet-5, deep=claude-opus-4-8.
# ANTHROPIC_MODEL is a legacy alias for ANTHROPIC_MODEL_FAST.
ANTHROPIC_MODEL_FAST=
ANTHROPIC_MODEL_DEEP=

# Optional: protects /api/cache/sync, /api/cache/sync-injuries, /api/cache/sync-conditions
# (Vercel Cron sends this automatically)
CRON_SECRET=

# Optional: Vegas odds (The Odds API, https://the-odds-api.com — free tier covers a daily
# batched pull). Without a key, game conditions fall back to nflverse's own closing lines.
ODDS_API_KEY=

# Optional: licensed FantasyPros expert-consensus-rankings API. Without a key, expert
# rankings fall back to a synthetic ADP+usage-trend estimate, clearly labeled as such.
FANTASYPROS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Phase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
